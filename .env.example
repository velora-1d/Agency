APP_NAME="Kantor Digital"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# DATABASE (PostgreSQL)
DB_CONNECTION=pgsql
DB_URL=postgresql://postgres:@127.0.0.1:5432/kantor_digital
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=kantor_digital
# DB_USERNAME=postgres
# DB_PASSWORD=

# CACHE & SESSION
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
CACHE_STORE=database
QUEUE_CONNECTION=database

# REDIS
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# REAL-TIME (Laravel Reverb)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME="http"

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# MAIL (SMTP / SendGrid / Mailchimp)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@kantordigital.test"
MAIL_FROM_NAME="${APP_NAME}"

# AUTH (Google SSO)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# STORAGE (Cloudflare R2)
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_REGION=auto
CLOUDFLARE_R2_PUBLIC_URL=

# PAYMENT GATEWAY (Pakasir)
PAKASIR_API_KEY=
PAKASIR_BASE_URL=https://api.pakasir.com/v1
PAKASIR_PROJECT=
PAKASIR_WEBHOOK_URL=

# WHATSAPP (Evolution API)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_GLOBAL_API_KEY=
EVOLUTION_DEFAULT_INSTANCE=

# AUTOMATION (n8n)
N8N_URL=http://localhost:5678
N8N_API_KEY=

# AI TOOLS (OpenAI / Claude / Gemini)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# MARKETING INTEGRATIONS
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

META_BUSINESS_ID=
META_BUSINESS_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=

MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=

# FINANCE DEFAULTS
DEFAULT_TAX_RATE=11
DEFAULT_CURRENCY=IDR

VITE_APP_NAME="${APP_NAME}"
